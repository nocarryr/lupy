{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    { "matchFileNames": [".github/workflows/*.lock.{yml,yaml}"], "enabled": false }
